DATABASE_URL=postgres://cefanet:cefanet@localhost:5432/cefanet_dnb
REDIS_URL=redis://localhost:6379
API_PORT=4000
JWT_SECRET=cefanet-demo-secret-change-in-prod
NEXT_PUBLIC_API_URL=http://localhost:4000
# When the web runs on Firebase Hosting, set this on Render (comma-separated, no spaces):
# CORS_ORIGIN=https://YOUR-PROJECT.web.app,https://YOUR-PROJECT.firebaseapp.com

# ---- KoboToolbox (optional; leave empty to show demo data) ----
KOBO_BASE=https://kf.kobotoolbox.org
KOBO_TOKEN=
KOBO_UID_PROJECT_UPDATE=
KOBO_UID_SCORECARD=
KOBO_UID_GRIEVANCE=
KOBO_UID_BURSARY=
KOBO_UID_HEALTH=

# Flip the Forms page from demo data to live API data (rebuild required)
NEXT_PUBLIC_KOBO_LIVE=false

# ---- Firebase Storage (optional; for real photo uploads) ----
# Get these from Firebase Console -> Project Settings -> "Your apps" -> Web app config.
# If left blank, the upload component runs in demo mode (compress + preview only).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
